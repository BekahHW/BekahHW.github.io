---
layout: null
permalink: /graph-data.json
---
{"posts":[{% for post in site.posts %}{"id":"post-{{ forloop.index }}","type":"post","title":"{{ post.title | escape }}","url":"{{ site.baseurl }}{{ post.url }}","date":"{{ post.date | date: '%b %Y' }}","tags":[{% for tag in post.tags %}"{{ tag }}"{% unless forloop.last %},{% endunless %}{% endfor %}],"excerpt":"{{ post.excerpt | strip_html | strip_newlines | escape | truncate: 150 }}"}{% unless forloop.last %},{% endunless %}{% endfor %}],"topics":[{% assign all_tags = site.tags | sort %}{% for tag in all_tags %}{% assign tag_name = tag | first %}{% assign tag_posts = tag | last %}{"id":"topic-{{ tag_name | downcase | replace: ' ', '-' }}","type":"topic","label":"{{ tag_name }}","count":{{ tag_posts | size }},"url":"{{ site.baseurl }}/tag/{{ tag_name | downcase | replace: ' ', '-' }}/"}{% unless forloop.last %},{% endunless %}{% endfor %}]}
