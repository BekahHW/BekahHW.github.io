<script>
(function () {
  'use strict';

  var timers = [];
  function later(fn, ms) { timers.push(setTimeout(fn, ms)); }
  function cancelAll() { timers.forEach(clearTimeout); timers = []; }

  var CTX_LIMIT = 2048;

  var STEPS = [
    { id: 'aic-s0', name: 'Retrieve',  icon: '­¤öŹ', tokens: 800 },
    { id: 'aic-s1', name: 'Summarize', icon: '­¤ōØ', tokens: 600 },
    { id: 'aic-s2', name: 'Format',    icon: '­¤Ä©', tokens: 700 },
    { id: 'aic-s3', name: 'Send',      icon: '­¤ōż', tokens: 400 }
  ];

  var runBtn   = document.getElementById('aic-run');
  var resetBtn = document.getElementById('aic-reset');
  var ctxFill  = document.getElementById('aic-ctx-fill');
  var ctxPct   = document.getElementById('aic-ctx-pct');
  var statusEl = document.getElementById('aic-status');

  function getStep(id) { return document.getElementById(id); }

  function setCtx(tokens) {
    var pct = Math.min(1, tokens / CTX_LIMIT);
    ctxFill.style.width = (pct * 100) + '%';
    ctxPct.textContent  = tokens + ' / ' + CTX_LIMIT;
    if (tokens > CTX_LIMIT) {
      ctxFill.classList.add('aic-ctx-over');
    }
  }

  function resetCtx() {
    cancelAll();
    if (runBtn) runBtn.disabled = false;

    STEPS.forEach(function (s) {
      var el = getStep(s.id);
      if (el) el.classList.remove('aic-step-running', 'aic-step-done', 'aic-step-error');
    });

    if (ctxFill) {
      ctxFill.style.width = '0%';
      ctxFill.classList.remove('aic-ctx-over');
    }
    if (ctxPct)   ctxPct.textContent = '0 / ' + CTX_LIMIT;
    if (statusEl) {
      statusEl.innerHTML  = 'Click <strong>Run Chain</strong> to watch the context window fill step by step.';
      statusEl.className  = 'aic-status';
    }
  }

  function runChain() {
    if (runBtn) runBtn.disabled = true;
    var accumulated = 0;
    var stepIdx     = 0;

    function nextStep() {
      if (stepIdx >= STEPS.length) {
        if (statusEl) {
          statusEl.innerHTML = 'Ō£ō Chain complete ŌĆö all steps finished within the context limit.';
          statusEl.className = 'aic-status aic-status-ok';
        }
        if (runBtn) runBtn.disabled = false;
        return;
      }

      var step = STEPS[stepIdx];
      var el   = getStep(step.id);

      if (el) el.classList.add('aic-step-running');
      if (statusEl) {
        statusEl.innerHTML = 'Running ' + step.icon + ' <strong>' + step.name + '</strong>ŌĆ”';
        statusEl.className = 'aic-status';
      }

      later(function () {
        accumulated += step.tokens;
        var overflow = accumulated > CTX_LIMIT;

        setCtx(accumulated);
        if (el) el.classList.remove('aic-step-running');

        if (overflow) {
          if (el) el.classList.add('aic-step-error');

          for (var i = stepIdx + 1; i < STEPS.length; i++) {
            var rem = getStep(STEPS[i].id);
            if (rem) rem.classList.add('aic-step-error');
          }

          if (statusEl) {
            statusEl.innerHTML =
              'ŌÜĀ’ĖÅ Context overflow at <strong>' + step.name + '</strong>! ' +
              accumulated + ' tokens accumulated ŌĆö limit is ' + CTX_LIMIT + '. ' +
              'Remaining steps were dropped.';
            statusEl.className = 'aic-status aic-status-error';
          }
          if (runBtn) runBtn.disabled = false;
          return;
        }

        if (el) el.classList.add('aic-step-done');
        stepIdx++;
        later(nextStep, 700);
      }, 900);
    }

    nextStep();
  }

  if (runBtn)   runBtn.addEventListener('click', runChain);
  if (resetBtn) resetBtn.addEventListener('click', resetCtx);

  if (window.MutationObserver) {
    var observer = new MutationObserver(function () {
      if (!document.getElementById('aic-ctx-window-demo')) {
        cancelAll();
        observer.disconnect();
      }
    });
    observer.observe(document.body, { childList: true, subtree: true });
  }

})();
</script>

<h3 id="malformed-outputs">Malformed outputs.</h3>

<p>If step three in your chain expects an organized JSON object and step two returns a casual paragraph of text, step three breaks. ItŌĆÖs like asking someone to fill out a form, but instead of using the form fields, they just write you a letter. The information might be there, but the system canŌĆÖt process it. This is why explicitly telling the LLM how to format its output, something like ŌĆ£respond only in JSON with these exact fields,ŌĆØ matters more than most people expect.</p>

<h3 id="latency-compounding">Latency compounding.</h3>

<p>Each step takes time. Three tools that each take two seconds is at minimum six seconds total, plus overhead. If youŌĆÖre building something people interact with in real time, that adds up fast. Builders solve this with caching, which means storing results youŌĆÖve already computed so you donŌĆÖt recalculate them, and parallelism, which means running independent steps at the same time instead of one after another.</p>

<h3 id="vague-instructions-at-the-orchestration-level">Vague instructions at the orchestration level.</h3>

<p>The LLM decides which tool to call next based on the instructions youŌĆÖve given it. Vague instructions lead to the wrong tool getting called, or the right tool getting called with the wrong inputs. Think of it like giving someone directions. ŌĆ£Head toward the big buildingŌĆØ leaves too much room for interpretation. ŌĆ£Turn left at the red light, go two blocks, turn right at the gas stationŌĆØ gets you where you need to go. The precision of your orchestration prompt determines whether your agent behaves reliably or keeps guessing.</p>

<h2 id="the-mental-shift-that-changes-how-you-ai">The mental shift that changes how you AI</h2>

<p>When you start thinking in tool chains, you stop asking ŌĆ£what can I get the AI to do?ŌĆØ and start asking ŌĆ£what does each step need to receive, and what does it need to output?ŌĆØ</p>

<p>ThatŌĆÖs a systems question. And itŌĆÖs actually a more useful frame than prompt craft alone, because it forces you to get specific about your requirements before you write a single instruction.</p>
