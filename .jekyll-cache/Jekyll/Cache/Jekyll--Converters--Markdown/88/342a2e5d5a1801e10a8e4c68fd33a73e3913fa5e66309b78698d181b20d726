    if (sf) { sf.classList.remove('jm-ok'); sf.classList.add('jm-err'); }
    if (si) si.textContent = 'Ō£Ś';
    if (ef) { ef.classList.remove('jm-ok'); ef.classList.add('jm-err'); }
    if (ei) ei.textContent = 'Ō£Ś';
  }

  function applyFixedField(i) {
    var sf = getSentField(i);
    var sk = getSentKey(i);
    var si = getSentInd(i);
    var ef = getExpField(i);
    var ei = getExpInd(i);
