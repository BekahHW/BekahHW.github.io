<script>
(function () {
  'use strict';

  var PATTERNS = [
    {
      id: 'aic-p0',
      label: 'Request/Response: One tool asks, the other answers. You send a prompt, you get text back, you pass it to the next step. Think of it like sending a text message and waiting for a reply before doing anything else.'
    },
    {
      id: 'aic-p1',
      label: 'Streaming: Instead of waiting for the full response, the output arrives piece by piece. This is why ChatGPT seems to type its answer in real time rather than making you wait for the whole thing to appear at once. It\'s useful when you\'re generating long content or building something that needs to feel responsive.'
    },
    {
      id: 'aic-p2',
      label: 'Events: Instead of asking and waiting, a tool watches for something to happen and then reacts. A new email arrives. A file is uploaded. A timer fires. The agent picks it up and acts without anyone pressing a button. This is how you build things that run in the background autonomously.'
    }
  ];

  var currentIdx = 0;
  var patternTimers = [];

  var prevBtn   = document.getElementById('aic-prev');
  var nextBtn   = document.getElementById('aic-next');
  var counterEl = document.getElementById('aic-counter');
  var labelEl   = document.getElementById('aic-pattern-label');
  var dots      = document.querySelectorAll('#aic-dots .aic-dot');

  function pLater(fn, ms) { patternTimers.push(setTimeout(fn, ms)); }
  function cancelPattern() { patternTimers.forEach(clearTimeout); patternTimers = []; }

  function showPattern(idx) {
    cancelPattern();

    PATTERNS.forEach(function (p) {
      var el = document.getElementById(p.id);
      if (el) el.classList.remove('aic-pattern-visible');
    });

    var target = document.getElementById(PATTERNS[idx].id);
    if (target) target.classList.add('aic-pattern-visible');

    dots.forEach(function (d, i) {
      d.classList.toggle('aic-dot-active', i === idx);
    });

    if (counterEl) counterEl.textContent = (idx + 1) + ' / ' + PATTERNS.length;
    if (labelEl)   labelEl.textContent   = PATTERNS[idx].label;
    if (prevBtn)   prevBtn.disabled      = idx === 0;
    if (nextBtn)   nextBtn.disabled      = idx === PATTERNS.length - 1;

    if (idx === 0) animRR();
    if (idx === 1) animStream();
    if (idx === 2) animEvents();
  }

  /* Pattern 0 ŌĆö Request / Response */
  function animRR() {
    var stateEl = document.getElementById('aic-rr-state');
    if (!stateEl) return;

    function cycle() {
      stateEl.innerHTML = '<div class="aic-waiting">' +
        '<div class="aic-waiting-dot"></div>' +
        '<div class="aic-waiting-dot"></div>' +
        '<div class="aic-waiting-dot"></div>' +
        '</div>';

      pLater(function () {
        stateEl.innerHTML = '<span style="font-size:0.8rem">"It\'s 3:42 PM."</span>';
      }, 2200);

      pLater(cycle, 4800);
    }

    cycle();
  }

  /* Pattern 1 ŌĆö Streaming */
  function animStream() {
    var textEl  = document.getElementById('aic-stream-text');
    if (!textEl) return;
    var words   = ["It's", " 3:42", " PM.", " Need", " anything", " else?"];
    var wordIdx = 0;

    function cycle() {
      textEl.textContent = '';
      wordIdx = 0;
      tick();
    }

    function tick() {
      if (wordIdx < words.length) {
        textEl.textContent += words[wordIdx];
        wordIdx++;
        pLater(tick, 260 + Math.floor(Math.random() * 160));
      } else {
        pLater(cycle, 2800);
      }
    }

    pLater(cycle, 300);
  }

  /* Pattern 2 ŌĆö Events */
  function animEvents() {
    var agentNode    = document.getElementById('aic-agent-node');
    var agentState   = document.getElementById('aic-agent-state');
    var triggerBadge = document.getElementById('aic-trigger-badge');
    var actionLine   = document.getElementById('aic-action-line');
    if (!agentNode || !agentState || !triggerBadge || !actionLine) return;

    function cycle() {
      agentNode.classList.remove('aic-agent-active');
      agentState.textContent = 'idle ŌĆö waiting';
      agentState.style.color = '';
      triggerBadge.classList.remove('aic-trigger-firing');
      actionLine.textContent = '';

      pLater(function () {
        triggerBadge.classList.add('aic-trigger-firing');
      }, 1400);

      pLater(function () {
        agentNode.classList.add('aic-agent-active');
        agentState.textContent = 'active';
        agentState.style.color = 'var(--aic-success)';
      }, 2400);

      pLater(function () {
        actionLine.textContent = 'Ō£ō Draft reply composed & sent';
      }, 3300);

      pLater(cycle, 6000);
    }

    cycle();
  }

  if (prevBtn) {
    prevBtn.addEventListener('click', function () {
      if (currentIdx > 0) { currentIdx--; showPattern(currentIdx); }
    });
  }

  if (nextBtn) {
    nextBtn.addEventListener('click', function () {
      if (currentIdx < PATTERNS.length - 1) { currentIdx++; showPattern(currentIdx); }
    });
  }

  dots.forEach(function (dot) {
    dot.addEventListener('click', function () {
      var idx = parseInt(dot.getAttribute('data-idx'), 10);
      if (!isNaN(idx)) { currentIdx = idx; showPattern(idx); }
    });
  });

  showPattern(0);

  if (window.MutationObserver) {
    var observer = new MutationObserver(function () {
      if (!document.getElementById('aic-patterns-demo')) {
        cancelPattern();
        observer.disconnect();
      }
    });
    observer.observe(document.body, { childList: true, subtree: true });
  }

})();
</script>

<p>Most builders start with request/response and eventually add streaming when their interface feels sluggish, or events when they want something to run without manual triggering. But the real magic happens when you combine them. You can have a tool chain that starts with an event trigger, streams output to the user, and then sends a final request/response message to update a database.</p>

<h2 id="what-actually-breaks-multi-step-chains">What Actually Breaks Multi-Step Chains</h2>

<p>Each of those three patterns works fine in isolation. Tool chains fail in very predictable ways. If you know the patterns, you know where to look. The problem shows up when you chain tools together and the context window (the AIŌĆÖs working memory) fills up.</p>

<h3 id="context-window-overflow">Context window overflow.</h3>

<p>Every LLM can only ŌĆ£seeŌĆØ a certain amount of text at once. Imagine trying to read a book but you can only ever see 10 pages at a time. If you keep shoving earlier chapters into the window to maintain ŌĆ£memory,ŌĆØ you eventually run out of room for the chapter youŌĆÖre actually trying to read. Builders who chain multiple tools together can accidentally fill the context window with outputs from earlier steps, leaving no room for the actual task. Smart builders decide what to pass forward and what to leave behind.</p>

