function nodePos(n) { return { x: n.x*W, y: n.y*H }; }

function draw() {
  animFrame++;
  ctx.clearRect(0, 0, W, H);

  if (!activeSession) {
    ctx.fillStyle = '#2a2560'; ctx.font = '13px -apple-system,sans-serif';
    ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
    ctx.fillText('select a session above to explore', W/2, H/2);
    return;
  }

  const {nodes, edges} = activeSession;

  // grid
  ctx.fillStyle = 'rgba(80,70,140,0.08)';
  for (let x=0;x<W;x+=30) for (let y=0;y<H;y+=30) { ctx.beginPath(); ctx.arc(x,y,1,0,Math.PI*2); ctx.fill(); }

  // edges
  edges.forEach(([a,b]) => {
    const na=nodes[a], nb=nodes[b], pa=nodePos(na), pb=nodePos(nb);
    const g = ctx.createLinearGradient(pa.x,pa.y,pb.x,pb.y);
    g.addColorStop(0, NODE_COLORS[na.type]+'55'); g.addColorStop(1, NODE_COLORS[nb.type]+'55');
    ctx.save(); ctx.strokeStyle=g; ctx.lineWidth=1.5; ctx.setLineDash([4,6]);
    ctx.beginPath(); ctx.moveTo(pa.x,pa.y); ctx.lineTo(pb.x,pb.y); ctx.stroke(); ctx.setLineDash([]);
    const dx=pb.x-pa.x, dy=pb.y-pa.y, len=Math.hypot(dx,dy);
    const ax=pb.x-(dx/len)*(nb.r+5), ay=pb.y-(dy/len)*(nb.r+5);
    ctx.fillStyle=NODE_COLORS[nb.type]+'70';
    ctx.beginPath(); ctx.translate(ax,ay); ctx.rotate(Math.atan2(dy,dx));
    ctx.moveTo(0,0); ctx.lineTo(-7,3); ctx.lineTo(-7,-3); ctx.closePath(); ctx.fill();
    ctx.restore();
  });

  // nodes
  nodes.forEach(n => {
    const p=nodePos(n), nc=NODE_COLORS[n.type];
    const r=n.r+(hoveredNode===n.id?3:0);
    const pulse=Math.sin(animFrame*0.035+n.id*1.3)*0.35+0.65;
    const sel=selectedNode===n.id;

    // glow
    const gr=r+20+(sel?10:0);
    const glow=ctx.createRadialGradient(p.x,p.y,r,p.x,p.y,gr);
    glow.addColorStop(0,nc+'50'); glow.addColorStop(1,nc+'00');
    ctx.save(); ctx.globalAlpha=pulse*(sel?1:0.65); ctx.fillStyle=glow;
    ctx.beginPath(); ctx.arc(p.x,p.y,gr,0,Math.PI*2); ctx.fill(); ctx.restore();

    // fill
    const fill=ctx.createRadialGradient(p.x-r*.3,p.y-r*.3,0,p.x,p.y,r);
    fill.addColorStop(0,nc+'cc'); fill.addColorStop(1,nc+'55');
    ctx.fillStyle=fill; ctx.beginPath(); ctx.arc(p.x,p.y,r,0,Math.PI*2); ctx.fill();
    ctx.strokeStyle=sel?'#fff':nc; ctx.lineWidth=sel?2.5:1.5; ctx.stroke();

    // label
    ctx.fillStyle='#fff'; ctx.textAlign='center'; ctx.textBaseline='middle';
    ctx.font=`${Math.max(9,Math.round(r*.40))}px -apple-system,sans-serif`;
    const lines=n.label.split('\n'), lh=r*.52, sy=p.y-((lines.length-1)*lh)/2;
    lines.forEach((ln,i) => ctx.fillText(ln, p.x, sy+i*lh));
  });

  // legend
  const lx=14, ly=H-44;
  [['task','#2dd4bf','Direct work'],['overhead','#a78bfa','Overhead / alignment']].forEach(([,c,lbl],i) => {
    ctx.fillStyle=c; ctx.beginPath(); ctx.arc(lx+5,ly+i*18,5,0,Math.PI*2); ctx.fill();
    ctx.fillStyle='#5550a0'; ctx.font='11px -apple-system,sans-serif';
    ctx.textAlign='left'; ctx.textBaseline='middle'; ctx.fillText(lbl,lx+15,ly+i*18);
  });
}

function animate() { draw(); requestAnimationFrame(animate); }
animate();

function getNodeAt(cx,cy) {
  if (!activeSession) return null;
  return activeSession.nodes.find(n => Math.hypot(cx-nodePos(n).x, cy-nodePos(n).y) <= n.r+10);
}

canvas.addEventListener('mousemove', e => {
  const r=canvas.getBoundingClientRect(), n=getNodeAt(e.clientX-r.left, e.clientY-r.top);
  hoveredNode=n?n.id:null; canvas.style.cursor=n?'pointer':'default';
});
canvas.addEventListener('click', e => {
  const r=canvas.getBoundingClientRect(), n=getNodeAt(e.clientX-r.left, e.clientY-r.top);
  if (!n) return;
  selectedNode=selectedNode===n.id?null:n.id;
  selectedNode!==null ? showNodeDetail(n) : clearDetail();
});
canvas.addEventListener('mouseleave', () => { hoveredNode=null; });
window.addEventListener('resize', resize);

function showNodeDetail(n) {
  document.getElementById('detailEmpty').style.display='none';
  document.getElementById('detailContent').style.display='block';
  document.getElementById('detailCard').classList.add('lit');
  const b=document.getElementById('dBadge');
