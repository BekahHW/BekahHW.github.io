  const b=document.getElementById('dBadge');
  b.textContent='message context'; b.style.background='#1a1848'; b.style.color='#818cf8';
  document.getElementById('dHeading').textContent='';
  document.getElementById('dBody').textContent=decodeURIComponent(enc);
  document.getElementById('dNote').style.display='none';
}

initTabs(); resize(); renderStrip();
</script>
