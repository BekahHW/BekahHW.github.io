  document.getElementById('dBody').textContent=n.body;
  const nt=document.getElementById('dNote');
  nt.textContent=n.note||''; nt.style.display=n.note?'block':'none';
}
function clearDetail() {
  document.getElementById('detailEmpty').style.display='flex';
  document.getElementById('detailContent').style.display='none';
  document.getElementById('detailCard').classList.remove('lit');
}

function sfFilter(type, btn) {
  sfType=type;
  document.querySelectorAll('.sf-btn').forEach(b => { b.classList.remove('active'); b.style.background=''; b.style.color=''; });
  btn.classList.add('active'); btn.style.background='#818cf8'; btn.style.color='#0a0914';
  renderStrip();
}

function renderStrip() {
  const scroll=document.getElementById('msgScroll');
  const all=activeSession?activeSession.msgs:SESSIONS.flatMap(s=>s.msgs);
  const filtered=all.filter(m=>sfType==='all'||m.kind===sfType);
  if (!filtered.length) { scroll.innerHTML='<div style="padding:16px;font-size:12px;color:#3a3870;">No messages in this view.</div>'; return; }
  scroll.innerHTML=filtered.map((m,i) => {
    const bc=m.kind==='task'?'#2dd4bf':'#a78bfa';
    return `<div class="msg-card" onclick="selectCard(this,'${encodeURIComponent(m.detail)}')" style="border-color:${bc}22">
      <div class="card-meta">
        <span class="role-badge ${m.role==='user'?'role-user':'role-asst'}">${m.role}</span>
        <span class="card-date">${m.date}</span>
      </div>
      <div class="card-text">${m.text}</div>
      <div class="card-bar" style="background:${bc}"></div>
    </div>`;
  }).join('');
}

function selectCard(el, enc) {
  document.querySelectorAll('.msg-card').forEach(c=>c.classList.remove('selected'));
  el.classList.add('selected');
  document.getElementById('detailEmpty').style.display='none';
  document.getElementById('detailContent').style.display='block';
