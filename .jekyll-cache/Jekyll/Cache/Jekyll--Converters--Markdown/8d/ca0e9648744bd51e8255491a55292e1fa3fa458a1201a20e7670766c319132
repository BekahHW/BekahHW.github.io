<script>
const messages = [
  {
    role: 'user', type: 'clarify', time: 'Mar 18',
    text: 'do you have a teleport command that pulls conversations from project conversations?',
    detail: 'Reveals that the two environments — Claude.ai Projects and Claude Code — don\'t share context. This question had to happen before any work could proceed. It\'s discovery overhead, not task work.'
  },
  {
    role: 'assistant', type: 'align', time: 'Mar 18',
    text: 'I can\'t directly access Claude.ai Projects — there\'s no integration between Claude Code and Claude.ai\'s project/conversation history.',
    detail: 'Alignment moment: correcting the user\'s mental model of how the two products relate. No failure. Just a shared-reality check that had to happen before work could begin.'
  },
  {
    role: 'user', type: 'task', time: 'Mar 18',
    text: 'I have a claude project with a blog post I want put into this repo. There are necessary diagrams. I want to hand the work of uploading and adding off to you.',
    detail: 'The actual task request — but notice it arrived only after two alignment exchanges resolved. And it carries unstated assumptions: file formats, directory structure, naming conventions.'
  },
  {
    role: 'user', type: 'align', time: 'Mar 18',
    text: 'they\'re svgs. You can find them in documents/ai blogpost',
    detail: 'Correcting the model\'s assumption about file format — it had written .png placeholders. One message, one correction, one re-pass. Small, but it required finding the mismatch first.'
  },
  {
    role: 'assistant', type: 'align', time: 'Mar 18',
    text: 'Two filenames don\'t match what\'s in the post: ai-llms-model.svg (not ai-llms-models.svg) and context_window.svg (not context-window.svg).',
    detail: 'Reality mismatch on filenames. The task (update image references) was simple. The alignment work — reconciling what the model assumed against what actually existed on disk — is where the friction lived.'
  },
  {
    role: 'user', type: 'confirm', time: 'Mar 18',
    text: 'does the 2026 folder exist? I don\'t see it',
    detail: 'A verification loop. The model created a directory silently. The user had to check if it actually existed. This adds no new work — it only validates prior work. Pure confirmation overhead.'
  },
  {
    role: 'user', type: 'task', time: 'Mar 20',
    text: 'create a new PR that updates the docs to replace ./tapes.db with ./tapes.sqlite throughout the docs.',
    detail: 'Clear, scoped task. Low alignment tax — the model had enough structural context to execute without back-and-forth. Technical tasks with precise specs consistently generate less alignment overhead than open-ended or visual tasks.'
  },
  {
    role: 'user', type: 'iterate', time: 'Mar 27',
    text: 'Keep the current design. Add 6–10 total CSS-only twinkles across the component. Make them sparse, elegant, warm-gold/ivory, and subtle. No glitter, no icons, no busy animation, no JS changes.',
    detail: 'The constraint list — "no glitter, no icons, no JS changes" — shows accumulated context from previous failed attempts. Each constraint was probably learned the hard way. Visual tasks carry the highest alignment tax in this session.'
  },
  {
    role: 'assistant', type: 'align', time: 'Mar 27',
    text: 'The sparkles are blurry glowing halos (8–20px blur), not sharp 1–2px dots — mine are invisible at that size. The active element has a dramatic ambient glow extending well beyond its border.',
    detail: 'The model looked at the reference image and realized its implementation didn\'t match. The user\'s intent was clear. The gap was between the visual reference and what the model could infer from words alone.'
  },
  {
    role: 'user', type: 'iterate', time: 'Mar 27',
    text: 'it doesn\'t look like the image I gave you. Are you able to see the image?',
    detail: 'Before iteration could continue, the parties had to confirm they were even looking at the same thing. This is a shared-reality check nested inside an iteration loop — alignment tax on top of iteration tax.'
  },
  {
    role: 'user', type: 'iterate', time: 'Mar 27',
    text: 'maybe the issue is the color palette. It looks dirty, not magical. the sparkles should be bright, like a star or a light bulb.',
    detail: '"Dirty" vs "magical" are not technical specs — they\'re subjective visual qualities the model had to map to hex values and opacity. Three full iteration cycles happened here before the palette landed.'
  },
  {
    role: 'assistant', type: 'align', time: 'Mar 27',
    text: 'The issue is clear — the palette is all muted amber-brown. Stars and light bulbs have a near-white/bright-yellow core. I need to shift sparkle colors toward bright white-yellow with high opacity.',
    detail: 'Successful alignment after three passes. The model finally decoded "dirty amber" → "not this" and "star/light bulb" → white-yellow core blooming outward. The technical fix was fast. The translation took the time.'
  },
];

let currentFilter = 'all';
let selectedIdx = null;

function filterMsgs(type, btn) {
  currentFilter = type;
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  selectedIdx = null;
  document.getElementById('detailPanel').classList.remove('visible');
  renderList();
}

function selectMsg(idx) {
  selectedIdx = idx;
  const m = messages[idx];
  document.getElementById('detailText').textContent = m.detail;
  document.getElementById('detailPanel').classList.add('visible');
  renderList();
}

function renderList() {
  const list = document.getElementById('msgList');
  const filtered = messages
    .map((m, i) => ({ ...m, origIdx: i }))
    .filter(m => currentFilter === 'all' || m.type === currentFilter);

  if (!filtered.length) {
    list.innerHTML = '<div style="padding:20px 16px; font-size:13px; color:#aaa;">No messages in this category.</div>';
    return;
  }

  list.innerHTML = filtered.map(m => `
    <div class="msg-row${selectedIdx === m.origIdx ? ' selected' : ''}" onclick="selectMsg(${m.origIdx})">
      <span class="badge badge-${m.role}">${m.role}</span>
      <span class="badge badge-${m.type}">${m.type}</span>
      <span class="msg-text">${m.text}</span>
      <span class="msg-time">${m.time}</span>
    </div>
  `).join('');
}

renderList();
</script>
</div>
